[Unit]
Description=DataBoard OpenWrt Metrics Collector (via SSH)
Documentation=https://github.com/gaofengcc/dataBoard
After=network.target

[Service]
Type=simple
User=gaofeng
Group=gaofeng
ExecStart=/home/gaofeng/dataBoard/scripts/collect_openwrt.sh --loop
Restart=always
RestartSec=5
Environment=COLLECT_INTERVAL=10

[Install]
WantedBy=multi-user.target
